@model IEnumerable<EmployeeCRM.Core.DTOs.ClientDTO>

@{
    ViewData["Title"] = "Clients";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>
                <i class="fas fa-user-tie"></i> Clients
            </h2>
        </div>
        <div class="col-md-4 text-end">
            @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
            {
                <a href="/Client/Create" class="btn btn-primary">
                    <i class="fas fa-building"></i> Add Client
                </a>
            }
        </div>
    </div>

    <!-- Search Form -->
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <form method="get" action="/Client/Index" class="row g-3">
                <div class="col-md-10">
                    <input type="text" name="searchTerm" class="form-control" 
                           placeholder="Search by company name, contact, or email..." 
                           value="@ViewBag.SearchTerm">
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-search"></i> Search
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Clients Table -->
    @if (Model.Any())
    {
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th><i class="fas fa-building"></i> Company</th>
                            <th><i class="fas fa-user"></i> Contact</th>
                            <th><i class="fas fa-envelope"></i> Email</th>
                            <th><i class="fas fa-phone"></i> Phone</th>
                            <th><i class="fas fa-star"></i> Rating</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var client in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@client.CompanyName</strong>
                                </td>
                                <td>@client.ContactName</td>
                                <td>@client.Email</td>
                                <td>@client.Phone</td>
                                <td>
                                    @if (client.Rating > 0)
                                    {
                                        <span class="badge bg-warning">
                                            <i class="fas fa-star"></i> @client.Rating/5
                                        </span>
                                    }
                                </td>
                                <td>
                                    <a href="/Client/Details/@client.Id" class="btn btn-sm btn-info" 
                                       title="View">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                                    {
                                        <a href="/Client/Edit/@client.Id" class="btn btn-sm btn-warning" 
                                           title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                    }
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a href="/Client/Delete/@client.Id" class="btn btn-sm btn-danger" 
                                           title="Delete" onclick="return confirm('Are you sure?')">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> No clients found.
        </div>
    }
</div>
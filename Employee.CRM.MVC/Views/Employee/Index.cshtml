@model IEnumerable<EmployeeCRM.Core.DTOs.EmployeeDTO>

@{
    ViewData["Title"] = "Employees";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>
                <i class="fas fa-users"></i> Employees
            </h2>
        </div>
        <div class="col-md-4 text-end">
            @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
            {
                <a href="/Employee/Create" class="btn btn-primary">
                    <i class="fas fa-user-plus"></i> Add Employee
                </a>
            }
        </div>
    </div>

    <!-- Search Form -->
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <form method="get" action="/Employee/Index" class="row g-3">
                <div class="col-md-10">
                    <input type="text" name="searchTerm" class="form-control" 
                           placeholder="Search by name or email..." 
                           value="@ViewBag.SearchTerm">
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-search"></i> Search
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Employees Table -->
    @if (Model.Any())
    {
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th><i class="fas fa-user"></i> Name</th>
                            <th><i class="fas fa-envelope"></i> Email</th>
                            <th><i class="fas fa-briefcase"></i> Position</th>
                            <th><i class="fas fa-money-bill"></i> Salary</th>
                            <th><i class="fas fa-calendar"></i> Join Date</th>
                            <th><i class="fas fa-flag"></i> Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var employee in Model)
                        {
                            <tr>
                                <td>@employee.FirstName @employee.LastName</td>
                                <td>@employee.Email</td>
                                <td>@employee.Position</td>
                                <td>@employee.Salary.ToString("C")</td>
                                <td>@employee.JoinDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <span class="badge bg-info">@employee.Status</span>
                                </td>
                                <td>
                                    <a href="/Employee/Details/@employee.Id" class="btn btn-sm btn-info" 
                                       title="View">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                                    {
                                        <a href="/Employee/Edit/@employee.Id" class="btn btn-sm btn-warning" 
                                           title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                    }
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a href="/Employee/Delete/@employee.Id" class="btn btn-sm btn-danger" 
                                           title="Delete" onclick="return confirm('Are you sure?')">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> No employees found.
        </div>
    }
</div>
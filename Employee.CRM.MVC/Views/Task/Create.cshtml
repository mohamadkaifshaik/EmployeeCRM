@model EmployeeCRM.Core.DTOs.TaskDTO

@{
    ViewData["Title"] = "Create Task";
}

<div class="container">
    <div class="row mb-4">
        <div class="col-md-12">
            <h2>
                <i class="fas fa-plus-circle"></i> Create New Task
            </h2>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0">Task Details</h5>
                </div>

                <div class="card-body">
                    <form method="post" novalidate>
                        <div class="mb-3">
                            <label for="Title" class="form-label">Task Title *</label>
                            <input type="text" class="form-control" asp-for="Title" required>
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label for="Description" class="form-label">Description</label>
                            <textarea class="form-control" asp-for="Description" rows="3"></textarea>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="Priority" class="form-label">Priority *</label>
                                <select class="form-select" asp-for="Priority" required>
                                    <option value="">-- Select Priority --</option>
                                    <option value="1">1 - Low</option>
                                    <option value="2">2 - Medium</option>
                                    <option value="3">3 - High</option>
                                </select>
                                <span asp-validation-for="Priority" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label for="DueDate" class="form-label">Due Date *</label>
                                <input type="date" class="form-control" asp-for="DueDate" required>
                                <span asp-validation-for="DueDate" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="EmployeeId" class="form-label">Assign To Employee *</label>
                                <input type="number" class="form-control" asp-for="EmployeeId" required>
                                <span asp-validation-for="EmployeeId" class="text-danger"></span>
                                <small class="text-muted">Enter Employee ID</small>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label for="ClientId" class="form-label">Related Client</label>
                                <input type="number" class="form-control" asp-for="ClientId">
                                <small class="text-muted">Enter Client ID (optional)</small>
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a href="/Task" class="btn btn-secondary">
                                <i class="fas fa-times"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-warning">
                                <i class="fas fa-save"></i> Create Task
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
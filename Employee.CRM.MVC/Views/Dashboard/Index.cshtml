@model EmployeeCRM.Core.DTOs.DashboardDTO

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-md-12">
            <h2 class="mb-4">
                <i class="fas fa-chart-line"></i> Dashboard
            </h2>
        </div>
    </div>

    @if (Model != null)
    {
        <!-- Key Metrics -->
        <div class="row mb-4">
            <!-- Total Employees -->
            <div class="col-md-3 mb-3">
                <div class="card border-primary shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="card-text text-muted">Total Employees</p>
                                <h3 class="card-title">@Model.TotalEmployees</h3>
                            </div>
                            <i class="fas fa-users fa-3x text-primary opacity-10"></i>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Total Clients -->
            <div class="col-md-3 mb-3">
                <div class="card border-success shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="card-text text-muted">Total Clients</p>
                                <h3 class="card-title">@Model.TotalClients</h3>
                            </div>
                            <i class="fas fa-building fa-3x text-success opacity-10"></i>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Total Tasks -->
            <div class="col-md-3 mb-3">
                <div class="card border-warning shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="card-text text-muted">Total Tasks</p>
                                <h3 class="card-title">@Model.TotalTasks</h3>
                            </div>
                            <i class="fas fa-tasks fa-3x text-warning opacity-10"></i>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Total Salary -->
            <div class="col-md-3 mb-3">
                <div class="card border-danger shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="card-text text-muted">Total Salaries</p>
                                <h3 class="card-title">@Model.TotalSalaries.ToString("C")</h3>
                            </div>
                            <i class="fas fa-money-bill-wave fa-3x text-danger opacity-10"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Task Status Overview -->
        <div class="row">
            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-chart-pie"></i> Task Status Overview
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-2">
                                <span>Completed Tasks</span>
                                <strong>@Model.CompletedTasks</strong>
                            </div>
                            <div class="progress" style="height: 25px;">
                                @{
                                    var completedPercent = Model.TotalTasks > 0 
                                        ? ((decimal)Model.CompletedTasks / Model.TotalTasks * 100) 
                                        : 0;
                                }
                                <div class="progress-bar bg-success" role="progressbar" 
                                     style="width: @completedPercent%">
                                    @completedPercent.ToString("F0")%
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-2">
                                <span>Pending Tasks</span>
                                <strong>@Model.PendingTasks</strong>
                            </div>
                            <div class="progress" style="height: 25px;">
                                @{
                                    var pendingPercent = Model.TotalTasks > 0 
                                        ? ((decimal)Model.PendingTasks / Model.TotalTasks * 100) 
                                        : 0;
                                }
                                <div class="progress-bar bg-warning" role="progressbar" 
                                     style="width: @pendingPercent%">
                                    @pendingPercent.ToString("F0")%
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-info-circle"></i> Quick Actions
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="list-group">
                            <a href="/Employee/Create" class="list-group-item list-group-item-action">
                                <i class="fas fa-user-plus"></i> Add New Employee
                            </a>
                            <a href="/Client/Create" class="list-group-item list-group-item-action">
                                <i class="fas fa-building"></i> Add New Client
                            </a>
                            <a href="/Task/Create" class="list-group-item list-group-item-action">
                                <i class="fas fa-plus-circle"></i> Create New Task
                            </a>
                            <a href="/Employee" class="list-group-item list-group-item-action">
                                <i class="fas fa-users"></i> View All Employees
                            </a>
                            <a href="/Client" class="list-group-item list-group-item-action">
                                <i class="fas fa-user-tie"></i> View All Clients
                            </a>
                            <a href="/Task" class="list-group-item list-group-item-action">
                                <i class="fas fa-list-check"></i> View All Tasks
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning">
            <i class="fas fa-exclamation-triangle"></i> Unable to load dashboard metrics.
        </div>
    }
</div>